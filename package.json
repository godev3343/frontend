    "openapi-typescript": "^7.13.0",
    "orval": "^8.9.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "core-js",
      "esbuild",
      "msw",
      "protobufjs",
      "sharp",
